{
  "name": "example",
  "version": "1.0.0",
  "main": "index",
  "scripts": {
    "start": "mkdir -p ../node_modules/react-native-worklets/.worklets && find ../node_modules/react-native-worklets/.worklets -mindepth 1 -maxdepth 1 -exec rm -rf {} + && expo start --dev-client --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@legendapp/list": "^3.0.0",
    "@react-navigation/native": "^7.1.27",
    "@react-navigation/native-stack": "^7.9.1",
    "expo": "^55.0.19",
    "expo-blur": "^55.0.14",
    "expo-dev-client": "^55.0.29",
    "expo-modules-core": "^55.0.24",
    "expo-status-bar": "^55.0.5",
    "react": "catalog:",
    "react-native": "catalog:",
    "react-native-gesture-handler": "^2.31.1",
    "@leonsilicon/react-native-list": "workspace:*",
    "react-native-nitro-modules": "catalog:",
    "react-native-reanimated": "4.5.0-nightly-20260620-9c2e3b052",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-worklets": "catalog:"
  },
  "devDependencies": {
    "@react-native/metro-config": "^0.83.1",
    "@types/react": "~19.1.0",
    "expo-build-properties": "^1.0.10",
    "typescript": "~5.9.2"
  },
  "expo": {
    "autolinking": {
      "searchPaths": [
        "../package"
      ]
    }
  },
  "worklets": {
    "staticFeatureFlags": {
      "BUNDLE_MODE_ENABLED": true,
      "FETCH_PREVIEW_ENABLED": false
    }
  },
  "private": true
}
